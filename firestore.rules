rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Block ALL access by default — no surprise collections
    match /{document=**} {
      allow read, write: if false;
    }

    // Only allow authenticated user to access their own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Limit write: must be owner, expected top-level shape only.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['invoices', 'todos', 'tracker'])
        && request.resource.data.invoices is list
        && request.resource.data.invoices.size() <= 1000
        && request.resource.data.todos is map
        && request.resource.data.todos.keys().hasOnly(['tasks', 'questions'])
        && request.resource.data.todos.tasks is list
        && request.resource.data.todos.questions is list
        && request.resource.data.todos.tasks.size() <= 5000
        && request.resource.data.todos.questions.size() <= 5000
        && request.resource.data.tracker is map;
    }
  }
}