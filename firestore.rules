rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Block ALL access by default — no surprise collections
    match /{document=**} {
      allow read, write: if false;
    }

    // Only allow authenticated user to access their own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Limit write: must be owner, doc must be under 1MB, invoices array capped at 500
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['invoices'])
        && request.resource.data.invoices is list
        && request.resource.data.invoices.size() <= 1000;
    }
  }
}